{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Requirement",
  "type": "object",
  "required": ["requirement_id", "title", "description", "owner_team", "milestone", "status", "priority"],
  "properties": {
    "requirement_id": { "type": "string" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "owner_team": { "type": "string" },
    "impacted_teams": { "type": "array", "items": { "type": "string" } },
    "upstream_dependencies": { "type": "array", "items": { "type": "string" } },
    "downstream_dependencies": { "type": "array", "items": { "type": "string" } },
    "milestone": { "type": "string" },
    "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
    "status": { "type": "string" },
    "priority": { "type": "string" },
    "risk_if_late": { "type": "string" },
    "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
